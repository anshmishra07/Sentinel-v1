PORT=4000
POLL_INTERVAL_MS=3000
# Set this to your deployed frontend URL in production. Use * only for temporary troubleshooting.
CLIENT_ORIGIN=http://localhost:5173

MONGODB_URI=mongodb://127.0.0.1:27017/devops_tracker

DEFAULT_CPU_THRESHOLD=80
DEFAULT_MEMORY_THRESHOLD=85
DEFAULT_DISK_THRESHOLD=90
DEVICE_OFFLINE_AFTER_MS=15000

# Email notifications
# Production SaaS mode:
# 1. Verify your sending domain in Resend.
# 2. Use a sender from that domain, for example alerts@yourdomain.com.
# 3. ALERT_EMAIL_TO can contain one or more recipients separated by commas.
RESEND_API_KEY=
ALERT_EMAIL_FROM=Sentinel Monitor <alerts@yourdomain.com>
ALERT_EMAIL_TO=admin@example.com,ops@example.com

# Optional Slack webhook
SLACK_WEBHOOK_URL=
